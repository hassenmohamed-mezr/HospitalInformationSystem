@using HospitalInformationSystem.ViewModels.CRUD_PatientViewMode
@model CreatePatientViewModel

@{
    ViewData["Title"] = "Register Patient";
}

<style>

    .form-wrapper {
        animation: fadeInUp 0.7s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-card {
        border: none;
        border-radius: 18px;
        transition: 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 45px rgba(0,0,0,0.12);
        }

    .section-title {
        font-weight: 700;
        margin-bottom: 20px;
    }

    .form-control,
    .form-select,
    textarea {
        border-radius: 12px;
        min-height: 46px;
        transition: 0.25s ease;
    }

        .form-control:focus,
        .form-select:focus,
        textarea:focus {
            transform: scale(1.01);
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.15);
        }

    .btn-action {
        border-radius: 12px;
        padding: 10px 18px;
        transition: 0.3s ease;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    .form-section {
        background: #f8f9fa;
        border-radius: 14px;
        padding: 15px;
        margin-bottom: 15px;
    }

</style>

<div class="container py-4 form-wrapper">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-8">

            <div class="card form-card shadow">

                <div class="card-body p-4 p-md-5">

                    <h2 class="section-title text-center">
                        Register Patient
                    </h2>

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All"
                             class="text-danger mb-3">
                        </div>

                        <!-- ROW 1 -->
                        <div class="row g-3">

                            <div class="col-12 col-md-6">

                                <label asp-for="FullName" class="form-label"></label>

                                <input asp-for="FullName"
                                       class="form-control"
                                       placeholder="Patient full name" />

                                <span asp-validation-for="FullName"
                                      class="text-danger small"></span>

                            </div>

                            <div class="col-12 col-md-6">

                                <label asp-for="DateOfBirth" class="form-label"></label>

                                <input asp-for="DateOfBirth"
                                       type="date"
                                       class="form-control" />

                                <span asp-validation-for="DateOfBirth"
                                      class="text-danger small"></span>

                            </div>

                        </div>

                        <!-- ROW 2 -->
                        <div class="row g-3 mt-1">

                            <div class="col-12 col-md-6">

                                <label asp-for="Gender" class="form-label"></label>

                                <select asp-for="Gender" class="form-select">
                                    <option value="">—</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>

                                <span asp-validation-for="Gender"
                                      class="text-danger small"></span>

                            </div>

                            <div class="col-12 col-md-6">

                                <label asp-for="NationalId" class="form-label"></label>

                                <input asp-for="NationalId"
                                       class="form-control"
                                       placeholder="National ID" />

                                <span asp-validation-for="NationalId"
                                      class="text-danger small"></span>

                            </div>

                        </div>

                        <!-- ADDRESS -->
                        <div class="mt-3">

                            <label asp-for="Address" class="form-label"></label>

                            <textarea asp-for="Address"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Full address"></textarea>

                            <span asp-validation-for="Address"
                                  class="text-danger small"></span>

                        </div>

                        <!-- PHONE -->
                        <div class="mt-3">

                            <label asp-for="PhoneNumber" class="form-label"></label>

                            <input asp-for="PhoneNumber"
                                   class="form-control"
                                   placeholder="Phone number" />

                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger small"></span>

                        </div>

                        <!-- ACTIVE -->
                        <div class="form-check mt-3 mb-4">

                            <input asp-for="IsActive"
                                   class="form-check-input" />

                            <label asp-for="IsActive"
                                   class="form-check-label">
                            </label>

                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex flex-column flex-sm-row gap-2">

                            <button type="submit"
                                    class="btn btn-success btn-action w-100">
                                Save Patient
                            </button>

                            <a class="btn btn-secondary btn-action w-100"
                               asp-action="Index">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}