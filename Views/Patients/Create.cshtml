@using HospitalInformationSystem.ViewModels.CRUD_PatientViewMode
@model CreatePatientViewModel

@{
    ViewData["Title"] = "Register Patient";
}

<div class="container py-4 app-page">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-8">

            <div class="card app-card shadow">

                <div class="app-card-header">
                    <h2 class="app-page-title mb-0 text-center">Register Patient</h2>
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All"
                             class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName"
                                       class="form-control"
                                       placeholder="Patient full name" />
                                <span asp-validation-for="FullName"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="DateOfBirth" class="form-label"></label>
                                <input asp-for="DateOfBirth"
                                       type="date"
                                       class="form-control" />
                                <span asp-validation-for="DateOfBirth"
                                      class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="Gender" class="form-label"></label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">—</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender"
                                      class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="NationalId" class="form-label"></label>
                                <input asp-for="NationalId"
                                       class="form-control"
                                       placeholder="National ID" />
                                <span asp-validation-for="NationalId"
                                      class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Full address"></textarea>
                            <span asp-validation-for="Address"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mt-4">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber"
                                   class="form-control"
                                   placeholder="Phone number" />
                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger small"></span>
                        </div>

                        <div class="form-check mt-3 mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <button type="submit" class="btn btn-success w-100">
                                Save Patient
                            </button>
                            <a class="btn btn-secondary w-100" asp-action="Index">Back</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}