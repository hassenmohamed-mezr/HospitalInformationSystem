@using HospitalInformationSystem.ViewModels.CRUD_PatientViewMode
@model EditPatientViewModel

@{
    ViewData["Title"] = "Edit Patient";
}

<div class="container py-4 app-page">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-8">

            <div class="card app-card shadow-lg">

                <div class="app-card-header">
                    <h2 class="app-page-title mb-0">Edit Patient</h2>
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="All"
                             class="text-danger mb-3"></div>

                        <h5 class="app-section-title">Personal Information</h5>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="DateOfBirth" class="form-label"></label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                        </div>

                        <h5 class="app-section-title mt-4">Identity</h5>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="Gender" class="form-label"></label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">—</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="NationalId" class="form-label"></label>
                                <input asp-for="NationalId" class="form-control" />
                                <span asp-validation-for="NationalId" class="text-danger small"></span>
                            </div>
                        </div>

                        <h5 class="app-section-title mt-4">Contact</h5>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="form-check mt-3 mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <button type="submit" class="btn btn-primary w-100">Save Changes</button>
                            <a class="btn btn-secondary w-100" asp-action="Index">Back</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}