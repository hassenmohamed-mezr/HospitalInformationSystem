@using HospitalInformationSystem.ViewModels.CRUD_PatientViewMode
@model EditPatientViewModel

@{
    ViewData["Title"] = "Edit Patient";
}

<style>

    .edit-wrapper {
        animation: fadeInUp 0.7s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .edit-card {
        border: none;
        border-radius: 20px;
        background: #ffffff;
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .edit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 55px rgba(0,0,0,0.12);
        }

    .header-bar {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        padding: 18px;
        text-align: center;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 18px;
        color: #1f2937;
    }

    .form-control,
    .form-select,
    textarea {
        border-radius: 12px;
        min-height: 46px;
        transition: all 0.25s ease;
        border: 1px solid #e5e7eb;
    }

        .form-control:focus,
        .form-select:focus,
        textarea:focus {
            transform: scale(1.01);
            border-color: #6366f1;
            box-shadow: 0 0 0 0.2rem rgba(99,102,241,0.15);
        }

    .form-group {
        margin-bottom: 14px;
    }

    .readonly-box {
        background: #f3f4f6;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
    }

    .btn-action {
        border-radius: 12px;
        padding: 10px 18px;
        transition: all 0.3s ease;
        font-weight: 600;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    .btn-primary:hover {
        box-shadow: 0 10px 25px rgba(13,110,253,0.25);
    }

    .btn-secondary:hover {
        box-shadow: 0 10px 25px rgba(108,117,125,0.25);
    }

    .form-check-input {
        border-radius: 6px;
    }

</style>

<div class="container py-4 edit-wrapper">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-8">

            <div class="card edit-card shadow-lg">

                <div class="header-bar">
                    Edit Patient
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="All"
                             class="text-danger mb-3">
                        </div>

                        <!-- PERSONAL INFO -->
                        <h5 class="section-title">Personal Information</h5>

                        <div class="row g-3">

                            <div class="col-12 col-md-6 form-group">

                                <label asp-for="FullName" class="form-label"></label>

                                <input asp-for="FullName"
                                       class="form-control" />

                                <span asp-validation-for="FullName"
                                      class="text-danger small"></span>

                            </div>

                            <div class="col-12 col-md-6 form-group">

                                <label asp-for="DateOfBirth" class="form-label"></label>

                                <input asp-for="DateOfBirth"
                                       type="date"
                                       class="form-control" />

                                <span asp-validation-for="DateOfBirth"
                                      class="text-danger small"></span>

                            </div>

                        </div>

                        <!-- IDENTITY -->
                        <h5 class="section-title mt-4">Identity</h5>

                        <div class="row g-3">

                            <div class="col-12 col-md-6 form-group">

                                <label asp-for="Gender" class="form-label"></label>

                                <select asp-for="Gender"
                                        class="form-select">
                                    <option value="">—</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>

                                <span asp-validation-for="Gender"
                                      class="text-danger small"></span>

                            </div>

                            <div class="col-12 col-md-6 form-group">

                                <label asp-for="NationalId" class="form-label"></label>

                                <input asp-for="NationalId"
                                       class="form-control" />

                                <span asp-validation-for="NationalId"
                                      class="text-danger small"></span>

                            </div>

                        </div>

                        <!-- CONTACT -->
                        <h5 class="section-title mt-4">Contact</h5>

                        <div class="form-group">

                            <label asp-for="Address" class="form-label"></label>

                            <textarea asp-for="Address"
                                      class="form-control"
                                      rows="3"></textarea>

                            <span asp-validation-for="Address"
                                  class="text-danger small"></span>

                        </div>

                        <div class="form-group">

                            <label asp-for="PhoneNumber" class="form-label"></label>

                            <input asp-for="PhoneNumber"
                                   class="form-control" />

                            <span asp-validation-for="PhoneNumber"
                                  class="text-danger small"></span>

                        </div>

                        <!-- STATUS -->
                        <div class="form-check mt-3 mb-4">

                            <input asp-for="IsActive"
                                   class="form-check-input" />

                            <label asp-for="IsActive"
                                   class="form-check-label">
                            </label>

                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex flex-column flex-sm-row gap-2">

                            <button type="submit"
                                    class="btn btn-primary btn-action w-100">
                                Save Changes
                            </button>

                            <a class="btn btn-secondary btn-action w-100"
                               asp-action="Index">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}