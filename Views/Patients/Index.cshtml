@model List<HospitalInformationSystem.Models.Patient>

@{
    ViewData["Title"] = "Patients";
}

<style>

    .patients-wrapper {
        animation: fadeInUp 0.6s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
    }

    .page-title {
        font-weight: 700;
        margin: 0;
    }

    .card-modern {
        border: none;
        border-radius: 16px;
        overflow: hidden;
    }

    .table thead {
        background: #111827;
        color: white;
    }

    .table tbody tr {
        transition: 0.2s ease;
    }

        .table tbody tr:hover {
            background: #f8fafc;
            transform: scale(1.002);
        }

    .badge-status {
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .action-group {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .action-btn {
        border-radius: 10px;
        padding: 4px 10px;
        font-size: 0.8rem;
        transition: 0.2s ease;
    }

        .action-btn:hover {
            transform: translateY(-1px);
        }

    .search-card {
        border: none;
        border-radius: 16px;
    }

</style>

<div class="container py-3 patients-wrapper">

    <!-- HEADER -->
    <div class="page-header">

        <h2 class="page-title">Patients</h2>

        <div class="d-flex gap-2 flex-wrap">

            <a class="btn btn-success"
               asp-action="Create">
                + Register Patient
            </a>

            @if (Context.Session.GetString("Role") == "Admin")
            {
                <a class="btn btn-secondary"
                   asp-controller="Admin"
                   asp-action="Index">
                    Back
                </a>
            }
            else
            {
                <a class="btn btn-secondary"
                   asp-controller="Reception"
                   asp-action="Index">
                    Back
                </a>
            }

        </div>

    </div>

    <!-- SEARCH -->
    <div class="card search-card shadow mb-4">

        <div class="card-header bg-light">
            <strong>Search Patients</strong>
        </div>

        <div class="card-body">

            <form asp-action="Index" method="get" class="row g-3">

                <div class="col-12 col-md-4">

                    <label class="form-label">Full name</label>

                    <input type="text"
                           class="form-control"
                           name="fullName"
                           value="@ViewBag.FullName" />

                </div>

                <div class="col-12 col-md-4">

                    <label class="form-label">National ID</label>

                    <input type="text"
                           class="form-control"
                           name="nationalId"
                           value="@ViewBag.NationalId" />

                </div>

                <div class="col-12 col-md-4">

                    <label class="form-label">Phone number</label>

                    <input type="text"
                           class="form-control"
                           name="phoneNumber"
                           value="@ViewBag.PhoneNumber" />

                </div>

                <div class="col-12">

                    <button type="submit"
                            class="btn btn-primary">
                        Search
                    </button>

                    <a class="btn btn-outline-secondary"
                       asp-action="Index">
                        Clear
                    </a>

                </div>

            </form>

        </div>

    </div>

    <!-- TABLE -->
    <div class="card card-modern shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>DOB</th>
                        <th>Gender</th>
                        <th>National ID</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th style="width:200px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var p in Model)
                    {
                        <tr>

                            <td class="fw-semibold">
                                @p.FullName
                            </td>

                            <td>
                                @(p.DateOfBirth.HasValue
                                                            ? p.DateOfBirth.Value.ToString("yyyy-MM-dd")
                                                            : "—")
                        </td>

                            <td>
                                @(string.IsNullOrEmpty(p.Gender) ? "—" : p.Gender)
                            </td>

                            <td>
                                @(string.IsNullOrEmpty(p.NationalId) ? "—" : p.NationalId)
                            </td>

                            <td>
                                @p.PhoneNumber
                            </td>

                            <td>
                            @if (p.IsActive)
                                {
                                    <span class="badge-status bg-success text-white">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-status bg-danger text-white">
                                        Inactive
                                    </span>
                                }
                            </td>

                            <td>

                                <div class="action-group">

                                    <a class="btn btn-sm btn-primary action-btn"
                                       asp-action="Edit"
                                       asp-route-id="@p.Id">
                                        Edit
                                    </a>

                                    <a class="btn btn-sm btn-info action-btn"
                                       href="/Visits/Index?patientId=@p.Id">
                                        Visits
                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- EMPTY STATE -->
    @if (Model.Count == 0)
    {
        <div class="text-center text-muted mt-4">
            <h5>No patients found</h5>
            <p>Try adjusting your search filters</p>
        </div>
    }

</div>