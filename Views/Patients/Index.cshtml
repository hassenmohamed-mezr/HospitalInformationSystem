@model List<HospitalInformationSystem.Models.Patient>

@{
    ViewData["Title"] = "Patients";
}

<div class="container py-3 app-page">

    <div class="app-page-header">

        <h2 class="app-page-title">Patients</h2>

        <div class="app-page-actions">

            <a class="btn btn-success"
               asp-action="Create">
                + Register Patient
            </a>

            @if (Context.Session.GetString("Role") == "Admin")
            {
                <a class="btn btn-secondary"
                   asp-controller="Admin"
                   asp-action="Index">
                    Back
                </a>
            }
            else
            {
                <a class="btn btn-secondary"
                   asp-controller="Reception"
                   asp-action="Index">
                    Back
                </a>
            }

        </div>

    </div>

    <div class="card app-card shadow mb-4">

        <div class="app-card-header">
            <strong>Search Patients</strong>
        </div>

        <div class="card-body">

            <form asp-action="Index" method="get" class="row g-3">

                <div class="col-12 col-md-4">
                    <label class="form-label">Full name</label>
                    <input type="text"
                           class="form-control"
                           name="fullName"
                           value="@ViewBag.FullName" />
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">National ID</label>
                    <input type="text"
                           class="form-control"
                           name="nationalId"
                           value="@ViewBag.NationalId" />
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">Phone number</label>
                    <input type="text"
                           class="form-control"
                           name="phoneNumber"
                           value="@ViewBag.PhoneNumber" />
                </div>

                <div class="col-12 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">Search</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
                </div>

            </form>

        </div>

    </div>

    <div class="card app-card shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0 app-table">

                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>DOB</th>
                        <th>Gender</th>
                        <th>National ID</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th class="action-cell">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@p.FullName</td>
                            <td>@(p.DateOfBirth.HasValue ? p.DateOfBirth.Value.ToString("yyyy-MM-dd") : "—")</td>
                            <td>@(string.IsNullOrEmpty(p.Gender) ? "—" : p.Gender)</td>
                            <td>@(string.IsNullOrEmpty(p.NationalId) ? "—" : p.NationalId)</td>
                            <td>@p.PhoneNumber</td>
                            <td>
                                <span class="app-badge-status @(p.IsActive ? "bg-success text-white" : "bg-danger text-white")">
                                    @(p.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="app-action-group">
                                    <a class="btn btn-sm btn-primary"
                                       asp-action="Edit"
                                       asp-route-id="@p.Id">
                                        Edit
                                    </a>
                                    <a class="btn btn-sm btn-info"
                                       asp-controller="Visits"
                                       asp-action="Index"
                                       asp-route-patientId="@p.Id">
                                        Visits
                                    </a>
                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-controller="Appointments"
                                       asp-action="Index"
                                       asp-route-patientId="@p.Id">
                                        Appointments
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

    @if (Model.Count == 0)
    {
        <div class="app-empty-state">
            <h5>No patients found</h5>
            <p>Try adjusting your search filters</p>
        </div>
    }

</div>