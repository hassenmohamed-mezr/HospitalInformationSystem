@using HospitalInformationSystem.ViewModels.CRUD_VisitViewMode
@model CreateVisitViewModel

@{
    ViewData["Title"] = "Create Visit";
    var patientId = Context.Request.Query["patientId"].ToString();
}

<style>

    .visit-wrapper {
        animation: fadeInUp 0.7s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .visit-card {
        border: none;
        border-radius: 20px;
        transition: 0.3s ease;
        overflow: hidden;
    }

        .visit-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 25px 55px rgba(0,0,0,0.12);
        }

    .header-bar {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        padding: 18px;
        text-align: center;
        font-weight: 700;
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 10px;
        color: #1f2937;
    }

    .form-control,
    .form-select,
    textarea {
        border-radius: 12px;
        min-height: 46px;
        transition: 0.25s ease;
    }

        .form-control:focus,
        .form-select:focus,
        textarea:focus {
            transform: scale(1.01);
            border-color: #6366f1;
            box-shadow: 0 0 0 0.2rem rgba(99,102,241,0.15);
        }

    .form-group {
        margin-bottom: 14px;
    }

    .btn-action {
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: 600;
        transition: 0.3s ease;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

</style>

<div class="container py-4 visit-wrapper">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-7">

            <div class="card visit-card shadow-lg">

                <div class="header-bar">
                    Create New Visit
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All"
                             class="text-danger mb-3">
                        </div>

                        <!-- PATIENT -->
                        <h5 class="section-title">Patient Information</h5>

                        @if (!string.IsNullOrEmpty(patientId))
                        {
                            <input type="hidden" asp-for="PatientId" value="@patientId" />

                            <div class="alert alert-info">
                                Patient already selected from previous page
                            </div>
                        }
                        else
                        {
                            <div class="form-group">

                                <label asp-for="PatientId" class="form-label"></label>

                                <select asp-for="PatientId"
                                        class="form-select"
                                        asp-items="@(ViewBag.Patients)">
                                    <option value="">-- Select Patient --</option>
                                </select>

                                <span asp-validation-for="PatientId"
                                      class="text-danger small"></span>

                            </div>
                        }

                        <!-- DOCTOR -->
                        <h5 class="section-title mt-3">Doctor Assignment</h5>

                        <div class="form-group">

                            <label asp-for="DoctorProfileId" class="form-label"></label>

                            <select asp-for="DoctorProfileId"
                                    class="form-select"
                                    asp-items="@(ViewBag.Doctors)">
                                <option value="">-- Select Doctor --</option>
                            </select>

                            <span asp-validation-for="DoctorProfileId"
                                  class="text-danger small"></span>

                        </div>

                        <!-- VISIT DETAILS -->
                        <h5 class="section-title mt-3">Visit Details</h5>

                        <div class="form-group">

                            <label asp-for="VisitDate" class="form-label"></label>

                            <input asp-for="VisitDate"
                                   type="datetime-local"
                                   class="form-control" />

                            <span asp-validation-for="VisitDate"
                                  class="text-danger small"></span>

                        </div>

                        <div class="form-group">

                            <label asp-for="Reason" class="form-label"></label>

                            <textarea asp-for="Reason"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Enter visit reason..."></textarea>

                            <span asp-validation-for="Reason"
                                  class="text-danger small"></span>

                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex flex-column flex-sm-row gap-2 mt-4">

                            <button type="submit"
                                    class="btn btn-success btn-action w-100">
                                Save Visit
                            </button>

                            <a class="btn btn-secondary btn-action w-100"
                               asp-action="Index">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}