@model List<HospitalInformationSystem.Models.Visit>

@{
    ViewData["Title"] = "Visits";
    var role = Context.Session.GetString("Role");
    var patientId = Context.Request.Query["patientId"].ToString();
}

<div class="container py-3 app-page">

    <div class="app-page-header">

        <h2 class="app-page-title">Visits</h2>

        <div class="app-page-actions">
            @if (role == "Reception")
            {
                if (!string.IsNullOrEmpty(patientId))
                {
                    <a class="btn btn-success"
                       asp-controller="Visits"
                       asp-action="Create"
                       asp-route-patientId="@patientId">
                        + Create Visit
                    </a>
                }
                else
                {
                    <a class="btn btn-success"
                       asp-action="Create">
                        + Create Visit
                    </a>
                }
            }
        </div>

    </div>

    <div class="card app-card shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0 app-table">

                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="action-cell">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var visit in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@visit.Patient.FullName</td>
                            <td>@visit.DoctorProfile.User.FullName</td>
                            <td>@visit.VisitDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="app-badge-status bg-primary text-white">
                                    @visit.Status
                                </span>
                            </td>
                            <td>
                                <div class="app-action-group">
                                    <a class="btn btn-sm btn-info"
                                       asp-action="Details"
                                       asp-route-id="@visit.Id">
                                        Details
                                    </a>
                                    @if (role == "Doctor")
                                    {
                                        <a class="btn btn-sm btn-primary"
                                           asp-action="Edit"
                                           asp-route-id="@visit.Id">
                                            Edit
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

    @if (Model.Count == 0)
    {
        <div class="app-empty-state">
            <h5>No visits found</h5>
            <p>There are currently no visit records to display.</p>
        </div>
    }

</div>