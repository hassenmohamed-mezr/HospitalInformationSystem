@model List<HospitalInformationSystem.Models.Visit>

@{
    ViewData["Title"] = "Visits";
    var role = Context.Session.GetString("Role");
    var patientId = Context.Request.Query["patientId"].ToString();
}

<style>

    .visits-wrapper {
        animation: fadeInUp 0.6s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
    }

    .page-title {
        font-weight: 700;
        margin: 0;
    }

    .table-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
    }

    .table thead {
        background: #111827;
        color: white;
    }

    .table tbody tr {
        transition: 0.2s ease;
    }

        .table tbody tr:hover {
            background: #f8fafc;
            transform: scale(1.002);
        }

    .badge-status {
        padding: 6px 10px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .action-btn {
        border-radius: 10px;
        padding: 4px 10px;
        font-size: 0.85rem;
        transition: 0.2s ease;
    }

        .action-btn:hover {
            transform: translateY(-1px);
        }

    .empty-state {
        text-align: center;
        padding: 30px;
        color: #6b7280;
    }

</style>

<div class="container py-3 visits-wrapper">

    <!-- HEADER -->
    <div class="page-header">

        <h2 class="page-title">Visits</h2>

        <div>

            @if (role == "Reception")
            {
                if (!string.IsNullOrEmpty(patientId))
                {
                    <a class="btn btn-success"
                       href="/Visits/Create?patientId=@patientId">
                        + Create Visit
                    </a>
                }
                else
                {
                    <a class="btn btn-success"
                       asp-action="Create">
                        + Create Visit
                    </a>
                }
            }

        </div>

    </div>

    <!-- TABLE -->
    <div class="card table-card shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th style="width:180px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var visit in Model)
                    {
                        <tr>

                            <td class="fw-semibold">
                                @visit.Patient.FullName
                            </td>

                            <td>
                                @visit.DoctorProfile.User.FullName
                            </td>

                            <td>
                                @visit.VisitDate.ToString("yyyy-MM-dd HH:mm")
                            </td>

                            <td>

                                <span class="badge-status bg-primary text-white">
                                    @visit.Status
                                </span>

                            </td>

                            <td>

                                <div class="d-flex gap-2 flex-wrap">

                                    <a class="btn btn-sm btn-info action-btn"
                                       asp-action="Details"
                                       asp-route-id="@visit.Id">
                                        Details
                                    </a>

                                    @if (role == "Doctor")
                                    {
                                        <a class="btn btn-sm btn-primary action-btn"
                                           asp-action="Edit"
                                           asp-route-id="@visit.Id">
                                            Edit
                                        </a>
                                    }

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- EMPTY STATE -->
    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <h5>No visits found</h5>
            <p>There are currently no visit records to display.</p>
        </div>
    }

</div>