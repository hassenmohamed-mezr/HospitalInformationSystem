@model List<HospitalInformationSystem.Models.Visit>

@{
    ViewData["Title"] = "Visits";
    var role = Context.Session.GetString("Role");
    var patientId = Context.Request.Query["patientId"].ToString();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Visits</h2>

    <div>
        @if (role == "Reception")
        {
            @if (!string.IsNullOrEmpty(patientId))
            {
                <a class="btn btn-success"
                   href="/Visits/Create?patientId=@patientId">
                    Create Visit
                </a>
            }
            else
            {
                <a class="btn btn-success" asp-action="Create">
                    Create Visit
                </a>
            }
        }
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Patient Name</th>
            <th>Doctor Name</th>
            <th>Date</th>
            <th>Status</th>
            <th style="width:180px;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var visit in Model)
        {
            <tr>
                <td>@visit.Patient.FullName</td>
                <td>@visit.DoctorProfile.User.FullName</td>
                <td>@visit.VisitDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@visit.Status</td>
                <td>
                    <a class="btn btn-sm btn-info"
                       asp-action="Details"
                       asp-route-id="@visit.Id">
                        Details
                    </a>

                    @if (role == "Doctor")
                    {
                        <a class="btn btn-sm btn-primary"
                           asp-action="Edit"
                           asp-route-id="@visit.Id">
                            Edit
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <p class="text-muted">No visits found.</p>
}