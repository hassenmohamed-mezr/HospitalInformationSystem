@model HospitalInformationSystem.Models.Visit

@{
    ViewData["Title"] = "Visit Details";
}

<div class="container py-4 app-page">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-8">

            <div class="card app-card shadow-lg">

                <div class="app-card-header">
                    <h2 class="app-page-title mb-0">Visit Details</h2>
                </div>

                <div class="card-body p-4 p-md-5">

                    <div class="row g-4">

                        <div class="col-12 col-md-6">

                            <div class="mb-3">
                                <div class="text-muted fw-semibold">Patient</div>
                                <div class="fw-semibold">
                                    @Model.Patient.FullName
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted fw-semibold">Doctor</div>
                                <div class="fw-semibold">
                                    @Model.DoctorProfile.User.FullName
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted fw-semibold">Visit Date</div>
                                <div class="fw-semibold">
                                    @Model.VisitDate.ToString("yyyy-MM-dd HH:mm")
                                </div>
                            </div>

                        </div>

                        <div class="col-12 col-md-6">

                            <div class="mb-3">
                                <div class="text-muted fw-semibold">Reason</div>
                                <div class="fw-semibold">
                                    @(string.IsNullOrWhiteSpace(Model.Reason) ? "—" : Model.Reason)
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted fw-semibold">Notes</div>
                                <div class="fw-semibold">
                                    @(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted fw-semibold">Status</div>
                                <span class="app-badge-status bg-primary text-white">
                                    @Model.Status
                                </span>
                            </div>

                        </div>

                    </div>

                    <hr class="my-4" />

                    <a class="btn btn-secondary w-100"
                       href="/Visits/Index?patientId=@Model.PatientId">
                        Back to Patient Visits
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>