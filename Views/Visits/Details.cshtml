@model HospitalInformationSystem.Models.Visit

@{
    ViewData["Title"] = "Visit Details";
}

<div class="card shadow">
    <div class="card-body">
        <h2>Visit Details</h2>

        <dl class="row">
            <dt class="col-sm-3">Patient</dt>
            <dd class="col-sm-9">@Model.Patient.FullName</dd>

            <dt class="col-sm-3">Doctor</dt>
            <dd class="col-sm-9">@Model.DoctorProfile.User.FullName</dd>

            <dt class="col-sm-3">Visit Date</dt>
            <dd class="col-sm-9">@Model.VisitDate.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Reason</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Reason) ? "—" : Model.Reason)</dd>

            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>

        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>
</div>
