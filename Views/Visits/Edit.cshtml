@using HospitalInformationSystem.Models
@using HospitalInformationSystem.ViewModels.CRUD_VisitViewMode
@model EditVisitViewModel

@{
    ViewData["Title"] = "Edit Visit";
}

<div class="container py-4 app-page">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-7">

            <div class="card app-card shadow-lg">

                <div class="app-card-header">
                    <h2 class="app-page-title mb-0">Edit Visit</h2>
                </div>

                <div class="card-body p-4 p-md-5">

                    @if (ViewBag.VisitInfo != null)
                    {
                        <div class="app-card-surface">
                            @ViewBag.VisitInfo
                        </div>
                    }

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="All"
                             class="text-danger mb-3"></div>

                        <h5 class="app-section-title">Doctor Notes</h5>

                        <div class="mb-3">
                            <textarea asp-for="Notes"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Write clinical notes..."></textarea>
                            <span asp-validation-for="Notes"
                                  class="text-danger small"></span>
                        </div>

                        <h5 class="app-section-title">Visit Status</h5>

                        <div class="mb-3">
                            <select asp-for="Status"
                                    class="form-select"
                                    asp-items="Html.GetEnumSelectList<VisitStatus>()"></select>
                            <span asp-validation-for="Status"
                                  class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
                            <button type="submit"
                                    class="btn btn-primary w-100">
                                Save Changes
                            </button>
                            <a class="btn btn-secondary w-100"
                               asp-action="Index">
                                Back
                            </a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}