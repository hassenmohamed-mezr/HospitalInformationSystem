@using HospitalInformationSystem.ViewModels.CRUD_UserViewModel
@model EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<style>

    .edit-wrapper {
        animation: fadeInUp 0.7s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .edit-card {
        border: none;
        border-radius: 20px;
        transition: 0.3s ease;
        overflow: hidden;
    }

        .edit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 55px rgba(0,0,0,0.12);
        }

    .header-bar {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        padding: 18px;
        text-align: center;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 12px;
        color: #1f2937;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        min-height: 46px;
        transition: 0.25s ease;
    }

        .form-control:focus,
        .form-select:focus {
            transform: scale(1.01);
            border-color: #6366f1;
            box-shadow: 0 0 0 0.2rem rgba(99,102,241,0.15);
        }

    .form-group {
        margin-bottom: 14px;
    }

    .btn-action {
        border-radius: 12px;
        padding: 10px 18px;
        transition: 0.3s ease;
        font-weight: 600;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

</style>

<div class="container py-4 edit-wrapper">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-7">

            <div class="card edit-card shadow-lg">

                <div class="header-bar">
                    Edit User
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="All"
                             class="text-danger mb-3">
                        </div>

                        <!-- ACCOUNT INFO -->
                        <h5 class="section-title">Account Information</h5>

                        <div class="row g-3">

                            <div class="col-12 col-md-6 form-group">

                                <label asp-for="FullName" class="form-label"></label>

                                <input asp-for="FullName"
                                       class="form-control" />

                                <span asp-validation-for="FullName"
                                      class="text-danger small"></span>

                            </div>

                            <div class="col-12 col-md-6 form-group">

                                <label asp-for="Username" class="form-label"></label>

                                <input asp-for="Username"
                                       class="form-control" />

                                <span asp-validation-for="Username"
                                      class="text-danger small"></span>

                            </div>

                        </div>

                        <div class="form-group">

                            <label asp-for="Email" class="form-label"></label>

                            <input asp-for="Email"
                                   class="form-control" />

                            <span asp-validation-for="Email"
                                  class="text-danger small"></span>

                        </div>

                        <!-- ROLE -->
                        <h5 class="section-title mt-4">Role Settings</h5>

                        <div class="form-group">

                            <label asp-for="Role" class="form-label"></label>

                            <select asp-for="Role"
                                    class="form-select">

                                <option value="Admin">Admin</option>
                                <option value="Doctor">Doctor</option>
                                <option value="Reception">Reception</option>

                            </select>

                            <span asp-validation-for="Role"
                                  class="text-danger small"></span>

                        </div>

                        <!-- STATUS -->
                        <div class="form-check mt-3 mb-4">

                            <input asp-for="IsActive"
                                   class="form-check-input" />

                            <label asp-for="IsActive"
                                   class="form-check-label">
                            </label>

                        </div>

                        <!-- ACTIONS -->
                        <div class="d-flex flex-column flex-sm-row gap-2">

                            <button type="submit"
                                    class="btn btn-primary btn-action w-100">
                                Save Changes
                            </button>

                            <a class="btn btn-secondary btn-action w-100"
                               asp-action="Index">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}