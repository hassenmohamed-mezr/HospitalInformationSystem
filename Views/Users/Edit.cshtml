@using HospitalInformationSystem.ViewModels.CRUD_UserViewModel
@model EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="container py-4 app-page">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-10 col-xl-7">

            <div class="card app-card shadow-lg">

                <div class="app-card-header">
                    <h2 class="app-page-title mb-0 text-center">Edit User</h2>
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <h5 class="app-section-title">Account Information</h5>

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="FullName" class="form-label"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="Username" class="form-label"></label>
                                <input asp-for="Username" class="form-control" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <h5 class="app-section-title mt-4">Role Settings</h5>

                        <div class="mb-3">
                            <label asp-for="Role" class="form-label"></label>
                            <select asp-for="Role" class="form-select">
                                <option value="Admin">Admin</option>
                                <option value="Doctor">Doctor</option>
                                <option value="Reception">Reception</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <div class="form-check mt-3 mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <button type="submit" class="btn btn-primary w-100">Save Changes</button>
                            <a class="btn btn-secondary w-100" asp-action="Index">Back</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}