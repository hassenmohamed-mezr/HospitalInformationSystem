@model List<HospitalInformationSystem.Models.User>

@{
    ViewData["Title"] = "Users Management";
}

<div class="container py-3 app-page">

    <div class="app-page-header">
        <h2 class="app-page-title">Users Management</h2>
        <div class="app-page-actions">
            <a class="btn btn-success" asp-action="Create">+ Add New User</a>
            <a class="btn btn-secondary" asp-controller="Admin" asp-action="Index">Back</a>
        </div>
    </div>

    <div class="card app-card shadow">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 app-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="action-cell">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@user.FullName</td>
                            <td>@user.Username</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="app-badge-status bg-primary text-white">@user.Role</span>
                            </td>
                            <td>
                                <span class="app-badge-status @(user.IsActive ? "bg-success text-white" : "bg-danger text-white")">
                                    @(user.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="app-action-group">
                                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                                    <a class="btn btn-sm btn-warning" asp-action="Deactivate" asp-route-id="@user.Id">Disable</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>