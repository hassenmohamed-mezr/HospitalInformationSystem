@model List<HospitalInformationSystem.Models.User>

@{
    ViewData["Title"] = "Users Management";
}

<style>

    .users-wrapper {
        animation: fadeInUp 0.6s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
    }

    .page-title {
        font-weight: 700;
        margin: 0;
    }

    .table-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
    }

    .table thead {
        background: #111827;
        color: white;
    }

    .table tbody tr {
        transition: 0.2s ease;
    }

        .table tbody tr:hover {
            background: #f1f5f9;
            transform: scale(1.002);
        }

    .badge {
        padding: 6px 10px;
        border-radius: 10px;
        font-weight: 600;
    }

    .action-btn {
        border-radius: 10px;
        padding: 4px 10px;
        font-size: 0.85rem;
        transition: 0.2s ease;
    }

        .action-btn:hover {
            transform: translateY(-1px);
        }

</style>

<div class="container py-3 users-wrapper">

    <!-- HEADER -->
    <div class="page-header">

        <h2 class="page-title">
            Users Management
        </h2>

        <div class="d-flex gap-2 flex-wrap">

            <a class="btn btn-success"
               asp-action="Create">
                + Add New User
            </a>

            <a class="btn btn-secondary"
               asp-controller="Admin"
               asp-action="Index">
                Back
            </a>

        </div>

    </div>

    <!-- TABLE CARD -->
    <div class="card table-card shadow">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th style="width:180px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var user in Model)
                    {
                        <tr>

                            <td class="fw-semibold">
                                @user.FullName
                            </td>

                            <td>
                                @user.Username
                            </td>

                            <td>
                                @user.Email
                            </td>

                            <td>
                                <span class="badge bg-primary">
                                    @user.Role
                                </span>
                            </td>

                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }
                            </td>

                            <td>

                                <div class="d-flex gap-2 flex-wrap">

                                    <a class="btn btn-sm btn-primary action-btn"
                                       asp-action="Edit"
                                       asp-route-id="@user.Id">
                                        Edit
                                    </a>

                                    <a class="btn btn-sm btn-warning action-btn"
                                       asp-action="Deactivate"
                                       asp-route-id="@user.Id">
                                        Disable
                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>