@model List<HospitalInformationSystem.Models.User>

@{
    ViewData["Title"] = "Users Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Users Management</h2>
    <div>
        <a class="btn btn-success" asp-action="Create">Add New User</a>
        <a class="btn btn-secondary" asp-controller="Admin" asp-action="Index">Back</a>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Full Name</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th style="width:180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Username</td>
                <td>@user.Email</td>
                <td>@user.Role</td>
                <td>
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                    <a class="btn btn-sm btn-warning" asp-action="Deactivate" asp-route-id="@user.Id">Deactivate</a>
                </td>
            </tr>
        }
    </tbody>
</table>