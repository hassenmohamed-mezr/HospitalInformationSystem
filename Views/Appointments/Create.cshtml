@model HospitalInformationSystem.ViewModels.CRUD_AppointmentViewMode.CreateAppointmentViewModel

@{
    ViewData["Title"] = "Create Appointment";
}

<div class="container py-3 app-page">

    <div class="app-page-header">
        <h2 class="app-page-title">📅 Create New Appointment</h2>
    </div>

    <div class="card app-card shadow" style="max-width: 700px; margin: 0 auto;">

        <div class="card-body p-4">

            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label asp-for="PatientId" class="form-label fw-semibold">Patient</label>
                    <select asp-for="PatientId" class="form-select" asp-items="ViewBag.Patients">
                        <option selected disabled>-- Select a patient --</option>
                    </select>
                    <span asp-validation-for="PatientId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DoctorProfileId" class="form-label fw-semibold">Doctor</label>
                    <select asp-for="DoctorProfileId" class="form-select" asp-items="ViewBag.Doctors">
                        <option selected disabled>-- Select a doctor --</option>
                    </select>
                    <span asp-validation-for="DoctorProfileId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="AppointmentDateTime" class="form-label fw-semibold">Date & Time</label>
                            <input asp-for="AppointmentDateTime" class="form-control" type="datetime-local" />
                            <span asp-validation-for="AppointmentDateTime" class="text-danger small"></span>
                            <small class="text-muted">⏰ Working hours: 9 AM - 5 PM</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Duration" class="form-label fw-semibold">Duration (minutes)</label>
                            <input asp-for="Duration" class="form-control" type="number" min="15" max="120" />
                            <span asp-validation-for="Duration" class="text-danger small"></span>
                            <small class="text-muted">15-120 minutes</small>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label fw-semibold">Notes (Optional)</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Add any special notes or instructions..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">✓ Create Appointment</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}