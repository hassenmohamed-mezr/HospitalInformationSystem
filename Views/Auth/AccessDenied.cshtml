<style>

    .access-wrapper {
        animation: fadeInUp 0.8s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(35px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .access-card {
        border-radius: 18px;
        transition: all 0.35s ease;
        background: rgba(255,255,255,0.95);
    }

        .access-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 45px rgba(0,0,0,0.15);
        }

    .access-title {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        animation: popIn 0.6s ease;
    }

    @@keyframes popIn {
        0% {
            transform: scale(0.8);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .access-btn {
        transition: all 0.3s ease;
        padding: 12px;
        font-weight: 600;
        border-radius: 12px;
    }

        .access-btn:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 25px rgba(13,110,253,0.25);
        }

</style>

<div class="container py-5 access-wrapper">

    <div class="row justify-content-center">

        <div class="col-12 col-sm-11 col-md-8 col-lg-6 col-xl-5">

            <div class="card access-card shadow border-0">

                <div class="card-body p-4 p-md-5 text-center">

                    <div class="mb-3">
                        <div style="font-size: 55px; animation: popIn 0.6s ease;">
                            ⛔
                        </div>
                    </div>

                    <h2 class="mb-3 text-danger access-title">
                        Access Denied
                    </h2>

                    <p class="text-muted mb-4">
                        You are not authorized to access this page.
                    </p>

                    <a class="btn btn-primary w-100 access-btn"
                       asp-controller="Auth"
                       asp-action="Login">
                        Go to Login
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>