@model HospitalInformationSystem.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    ViewData["BodyClass"] = "login-bg";
}

<style>

    body.login-bg {
        background: linear-gradient(135deg, #0f172a, #1e293b, #111827);
        background-size: 400% 400%;
        animation: gradientMove 12s ease infinite;
        overflow-x: hidden;
    }

    @@keyframes gradientMove {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .login-wrapper {
        animation: fadeInUp 1s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .login-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.4s ease;
    }

        .login-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
        }

    .login-title {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .form-label {
        color: #e5e7eb;
        font-weight: 600;
    }

    .form-control {
        background-color: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: white;
        height: 55px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background-color: rgba(255, 255, 255, 0.12);
            color: white;
            border-color: #6366f1;
            box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.25);
            transform: scale(1.01);
        }

        .form-control::placeholder {
            color: #cbd5e1;
        }

    .login-btn {
        height: 55px;
        font-size: 1.1rem;
        font-weight: 600;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        transition: all 0.3s ease;
    }

        .login-btn:hover {
            transform: translateY(-2px) scale(1.01);
            box-shadow: 0 10px 25px rgba(124, 58, 237, 0.4);
        }

    .login-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 2rem;
        color: white;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
        }
    }

    @@media (max-width: 576px) {

        .login-card {
            border-radius: 24px !important;
        }

        .card-body {
            padding: 2rem !important;
        }

        .login-title {
            font-size: 1.7rem;
        }
    }

</style>

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center py-4">

    <div class="row justify-content-center w-100 login-wrapper">

        <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">

            <div class="card login-card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-4">

                        <div class="login-icon">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>

                        <h2 class="login-title text-white">
                            Welcome Back
                        </h2>

                        <p class="text-light opacity-75 mb-0">
                            Login to continue to the system
                        </p>

                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center rounded-3 border-0">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Login" method="post">

                        <div asp-validation-summary="All"
                             class="text-danger mb-4">
                        </div>

                        <div class="mb-4">

                            <label asp-for="UsernameOrEmail"
                                   class="form-label">
                            </label>

                            <input asp-for="UsernameOrEmail"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Enter username or email" />

                            <span asp-validation-for="UsernameOrEmail"
                                  class="text-danger small">
                            </span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Password"
                                   class="form-label">
                            </label>

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Enter password" />

                            <span asp-validation-for="Password"
                                  class="text-danger small">
                            </span>

                        </div>

                        <button type="submit"
                                class="btn login-btn btn-lg w-100 rounded-3 text-white">
                            Login
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}