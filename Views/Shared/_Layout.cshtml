<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - HospitalInformationSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="icon" type="image/x-icon" href="~/hospital-facility.png" />

    <style>

        /* ===== NAVBAR MODERN ===== */
        .custom-navbar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }

            .custom-navbar .nav-link {
                color: #e5e7eb !important;
                transition: 0.25s ease;
                border-radius: 10px;
                padding: 6px 12px;
            }

                .custom-navbar .nav-link:hover {
                    background: rgba(255,255,255,0.08);
                    transform: translateY(-1px);
                }

            .custom-navbar .navbar-brand {
                font-weight: 700;
                letter-spacing: 0.5px;
            }

        .active-link {
            background: rgba(99,102,241,0.25);
            color: #fff !important;
        }

        .user-badge {
            background: rgba(255,255,255,0.08);
            padding: 6px 12px;
            border-radius: 12px;
            color: #e5e7eb;
        }

        body {
            background: #f8fafc;
        }
    </style>

</head>

<body class="@ViewData["BodyClass"]">

    @{
        var username = Context.Session.GetString("Username");
        var role = Context.Session.GetString("Role");
    }

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar sticky-top">

        <div class="container-fluid">

            <a class="navbar-brand text-white"
               asp-controller="Auth"
               asp-action="Login">
                🏥 Hospital System
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <!-- LEFT MENU -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    @if (!string.IsNullOrEmpty(username))
                    {

                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Users" asp-action="Index">Users</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Doctors" asp-action="Index">Doctors</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Patients" asp-action="Index">Patients</a>
                            </li>
                        }

                        @if (role == "Doctor")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Doctor" asp-action="Index">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Patients" asp-action="Index">Patients</a>
                            </li>
                        }

                        @if (role == "Reception")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reception" asp-action="Index">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Patients" asp-action="Index">Patients</a>
                            </li>
                        }

                    }

                </ul>

                <!-- RIGHT MENU -->
                <ul class="navbar-nav ms-auto align-items-center gap-2">

                    @if (!string.IsNullOrEmpty(username))
                    {
                        <li class="nav-item">
                            <span class="user-badge">
                                @username (@role)
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-warning"
                               asp-controller="Auth"
                               asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <!-- MAIN CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>