@model ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<style>

    .error-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.6s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .error-card {
        border: none;
        border-radius: 18px;
        max-width: 600px;
        width: 100%;
        transition: 0.3s ease;
    }

        .error-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        }

    .error-icon {
        font-size: 3rem;
        color: #dc3545;
        margin-bottom: 10px;
    }

    .error-title {
        font-weight: 700;
    }

    .dev-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 12px;
        font-size: 0.9rem;
        color: #6c757d;
    }

    .request-id {
        font-family: monospace;
        background: #f1f5f9;
        padding: 4px 8px;
        border-radius: 8px;
    }

</style>

<div class="container error-wrapper">

    <div class="card error-card shadow-lg">

        <div class="card-body p-4 p-md-5 text-center">

            <div class="error-icon">⚠️</div>

            <h2 class="text-danger error-title">
                Something went wrong
            </h2>

            <p class="text-muted mb-4">
                An unexpected error occurred while processing your request.
            </p>

            @if (Model.ShowRequestId)
            {
                <p class="mb-3">
                    <strong>Request ID:</strong>
                    <span class="request-id">@Model.RequestId</span>
                </p>
            }

            <div class="dev-box text-start mt-4">

                <h6 class="text-dark mb-2">Development Note</h6>

                <p class="mb-2">
                    Enable <strong>Development</strong> mode to see detailed error information.
                </p>

                <p class="mb-0">
                    Do not use Development mode in production environments as it may expose sensitive data.
                </p>

            </div>

            <div class="mt-4">

                <a class="btn btn-primary w-100"
                   href="/">
                    Go to Home
                </a>

            </div>

        </div>

    </div>

</div>