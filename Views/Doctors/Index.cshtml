@model List<HospitalInformationSystem.Models.DoctorProfile>

@{
    ViewData["Title"] = "Doctors";
}

<div class="container py-4 app-page">

    <div class="app-page-header">
        <h2 class="app-page-title">Doctors</h2>
        <div class="app-page-actions">
            <a class="btn btn-success"
               asp-action="Create">
                Add Doctor Profile
            </a>
            <a class="btn btn-secondary"
               asp-controller="Admin"
               asp-action="Index">
                Back
            </a>
        </div>
    </div>

    <div class="card app-card shadow-sm mb-4">
        <div class="app-card-header">
            <strong>Search</strong>
        </div>
        <div class="card-body">
            <form asp-action="Search"
                  method="get"
                  class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Doctor Name</label>
                    <input type="text"
                           class="form-control"
                           name="fullName"
                           value="@ViewBag.FullName" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Specialty</label>
                    <input type="text"
                           class="form-control"
                           name="specialty"
                           value="@ViewBag.Specialty" />
                </div>
                <div class="col-12 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">Search</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card app-card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0 app-table">
                <thead class="table-dark">
                    <tr>
                        <th>Doctor</th>
                        <th>Specialty</th>
                        <th>Room</th>
                        <th>Experience</th>
                        <th>Status</th>
                        <th class="action-cell">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td>
                                <strong>@d.User.FullName</strong><br />
                                <small class="text-muted">@d.User.Username</small>
                            </td>
                            <td>@d.Specialty</td>
                            <td>@(string.IsNullOrEmpty(d.Room) ? "—" : d.Room)</td>
                            <td>@(d.YearsOfExperience.HasValue ? $"{d.YearsOfExperience} years" : "—")</td>
                            <td>
                                @if (d.IsActive)
                                {
                                    <span class="app-badge-status bg-success text-white">Active</span>
                                }
                                else
                                {
                                    <span class="app-badge-status bg-danger text-white">Inactive</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@d.Id">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="app-empty-state">
            No doctor profiles found.
        </div>
    }

</div>