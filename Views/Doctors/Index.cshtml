@model List<HospitalInformationSystem.Models.DoctorProfile>

@{
    ViewData["Title"] = "Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Doctors</h2>
    <div>
        <a class="btn btn-success" asp-action="Create">Add Doctor Profile</a>
        <a class="btn btn-secondary" asp-controller="Admin" asp-action="Index">Back</a>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header bg-light">
        <strong>Search</strong>
    </div>
    <div class="card-body">
        <form asp-action="Search"
			  method="get"
			  class="row g-3">

            <div class="col-md-6">
                <label class="form-label">Doctor Name</label>
                <input type="text" class="form-control" name="fullName" value="@ViewBag.FullName" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Specialty</label>
                <input type="text" class="form-control" name="specialty" value="@ViewBag.Specialty" />
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Search</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
            </div>

        </form>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Doctor</th>
            <th>Specialty</th>
            <th>Room</th>
            <th>Experience</th>
            <th>Status</th>
            <th style="width:120px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.User.FullName (@d.User.Username)</td>
                <td>@d.Specialty</td>
                <td>@(string.IsNullOrEmpty(d.Room) ? "—" : d.Room)</td>
                <td>@(d.YearsOfExperience.HasValue ? $"{d.YearsOfExperience} years" : "—")</td>
                <td>
                    @if (d.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@d.Id">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <p class="text-muted">No doctor profiles found.</p>
}
