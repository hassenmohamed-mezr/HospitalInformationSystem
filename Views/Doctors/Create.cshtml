@using HospitalInformationSystem.ViewModels.CRUD_DoctorProfileViewMode
@model CreateDoctorProfileViewModel

@{
    ViewData["Title"] = "Create Doctor Profile";
}

<style>

    .form-wrapper {
        animation: fadeInUp 0.7s ease;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-card {
        border: none;
        border-radius: 18px;
        transition: 0.3s ease;
    }

        .form-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 45px rgba(0,0,0,0.12);
        }

    .form-title {
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        height: 48px;
        transition: 0.25s ease;
    }

        .form-control:focus,
        .form-select:focus {
            transform: scale(1.01);
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.15);
        }

    .form-label {
        font-weight: 600;
    }

    .btn-action {
        border-radius: 12px;
        padding: 10px 18px;
        transition: 0.3s ease;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

    .btn-success:hover {
        box-shadow: 0 10px 25px rgba(25,135,84,0.25);
    }

    .btn-secondary:hover {
        box-shadow: 0 10px 25px rgba(108,117,125,0.25);
    }

</style>

<div class="container py-4 form-wrapper">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-8 col-xl-6">

            <div class="card form-card shadow">

                <div class="card-body p-4 p-md-5">

                    <h2 class="form-title mb-4 text-center">
                        Create Doctor Profile
                    </h2>

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All"
                             class="text-danger mb-3">
                        </div>

                        <!-- Doctor User -->
                        <div class="mb-3">

                            <label asp-for="UserId" class="form-label">
                                Doctor User
                            </label>

                            <select asp-for="UserId"
                                    class="form-select"
                                    asp-items="@(ViewBag.DoctorUsers)">
                                <option value="">-- Select Doctor User --</option>
                            </select>

                            <span asp-validation-for="UserId"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- Specialty -->
                        <div class="mb-3">

                            <label asp-for="Specialty" class="form-label"></label>

                            <input asp-for="Specialty"
                                   class="form-control"
                                   placeholder="e.g. Cardiology" />

                            <span asp-validation-for="Specialty"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- Room -->
                        <div class="mb-3">

                            <label asp-for="Room" class="form-label"></label>

                            <input asp-for="Room"
                                   class="form-control"
                                   placeholder="Room number" />

                            <span asp-validation-for="Room"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- Experience -->
                        <div class="mb-3">

                            <label asp-for="YearsOfExperience" class="form-label"></label>

                            <input asp-for="YearsOfExperience"
                                   class="form-control"
                                   type="number"
                                   min="0"
                                   placeholder="Years of experience" />

                            <span asp-validation-for="YearsOfExperience"
                                  class="text-danger small">
                            </span>

                        </div>

                        <!-- Active -->
                        <div class="form-check mb-4">

                            <input asp-for="IsActive"
                                   class="form-check-input" />

                            <label asp-for="IsActive"
                                   class="form-check-label">
                            </label>

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex flex-column flex-sm-row gap-2">

                            <button type="submit"
                                    class="btn btn-success btn-action w-100">
                                Save
                            </button>

                            <a class="btn btn-secondary btn-action w-100"
                               asp-action="Index">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}