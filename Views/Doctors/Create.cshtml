@using HospitalInformationSystem.ViewModels.CRUD_DoctorProfileViewMode
@model CreateDoctorProfileViewModel

@{
    ViewData["Title"] = "Create Doctor Profile";
}

<div class="container py-4 app-page">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-8 col-xl-6">

            <div class="card app-card shadow">

                <div class="app-card-header">
                    <h2 class="app-page-title mb-0 text-center">Create Doctor Profile</h2>
                </div>

                <div class="card-body p-4 p-md-5">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All"
                             class="text-danger mb-3"></div>

                        <h5 class="app-section-title">Doctor User</h5>

                        <div class="mb-3">
                            <label asp-for="UserId" class="form-label"></label>
                            <select asp-for="UserId"
                                    class="form-select"
                                    asp-items="@(ViewBag.DoctorUsers)">
                                <option value="">-- Select Doctor User --</option>
                            </select>
                            <span asp-validation-for="UserId"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Specialty" class="form-label"></label>
                            <input asp-for="Specialty"
                                   class="form-control"
                                   placeholder="e.g. Cardiology" />
                            <span asp-validation-for="Specialty"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Room" class="form-label"></label>
                            <input asp-for="Room"
                                   class="form-control"
                                   placeholder="Room number" />
                            <span asp-validation-for="Room"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="YearsOfExperience" class="form-label"></label>
                            <input asp-for="YearsOfExperience"
                                   class="form-control"
                                   type="number"
                                   min="0"
                                   placeholder="Years of experience" />
                            <span asp-validation-for="YearsOfExperience"
                                  class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <button type="submit" class="btn btn-success w-100">
                                Save
                            </button>
                            <a class="btn btn-secondary w-100" asp-action="Index">Back</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}