@using HospitalInformationSystem.ViewModels.CRUD_DoctorProfileViewMode
@model EditDoctorProfileViewModel

@{
    ViewData["Title"] = "Edit Doctor Profile";
}

<div class="container py-4 app-page">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-8 col-xl-6">

            <div class="card app-card shadow">

                <div class="app-card-header">
                    <h2 class="app-page-title mb-0 text-center">Edit Doctor Profile</h2>
                </div>

                <div class="card-body p-4 p-md-5">

                    <div class="mb-4">
                        <label class="form-label text-muted">Doctor User</label>
                        <input class="form-control bg-light"
                               value="@ViewBag.DoctorName"
                               readonly />
                    </div>

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UserId" />

                        <div asp-validation-summary="All"
                             class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Specialty" class="form-label"></label>
                            <input asp-for="Specialty"
                                   class="form-control"
                                   placeholder="Specialty" />
                            <span asp-validation-for="Specialty"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Room" class="form-label"></label>
                            <input asp-for="Room"
                                   class="form-control"
                                   placeholder="Room number" />
                            <span asp-validation-for="Room"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="YearsOfExperience" class="form-label"></label>
                            <input asp-for="YearsOfExperience"
                                   class="form-control"
                                   type="number"
                                   min="0"
                                   placeholder="Years of experience" />
                            <span asp-validation-for="YearsOfExperience"
                                  class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-2">
                            <button type="submit" class="btn btn-primary w-100">
                                Save Changes
                            </button>
                            <a class="btn btn-secondary w-100" asp-action="Index">Back</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}